# LLM Provider — openai | anthropic | gemini | ollama
LLM_PROVIDER=openai

# Model selection (override defaults)
ORCHESTRATOR_MODEL=gpt-4o
AGENT_MODEL=gpt-4o-mini

# --- API Keys (set only the one you need) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Ollama (local models, no key required)
OLLAMA_BASE_URL=http://localhost:11434

# State store
DB_PATH=clinkz.db

# Tool execution timeout in seconds
TOOL_TIMEOUT=300

# MCP servers — JSON list of server commands or URLs
# stdio command: ["burpsuite-mcp"]  or  ["python", "/path/to/server.py"]
# HTTP/SSE URL:  ["http://localhost:8080/mcp"]
# Multiple:      ["burpsuite-mcp", "http://localhost:9000/mcp"]
MCP_SERVERS=[]
