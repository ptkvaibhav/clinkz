      <!-- Highest accuracy match comes first -->
      <osmatch name="Linux 5.4 - 5.15" accuracy="96" line="65535">
        <osclass type="general purpose" vendor="Linux" osfamily="Linux" osgen="5.X" accuracy="96">
          <cpe>cpe:/o:linux:linux_kernel:5</cpe>
        </osclass>
      </osmatch>
      <osmatch name="Ubuntu 22.04 LTS (Jammy Jellyfish)" accuracy="94" line="65530">
        <osclass type="general purpose" vendor="Canonical" osfamily="Linux" osgen="22.04" accuracy="94">
          <cpe>cpe:/o:canonical:ubuntu_linux:22.04</cpe>
        </osclass>
      </osmatch>
    </os>

    <uptime seconds="86400" lastboot="Mon Mar  3 09:06:40 2025"/>
    <times srtt="1234" rttvar="567" to="100000"/>
  </host>

  <runstats>
