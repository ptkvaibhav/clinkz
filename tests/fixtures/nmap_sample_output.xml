<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nmaprun>
<?xml-stylesheet href="file:///usr/bin/../share/nmap/nmap.xsl" type="text/xsl"?>
<nmaprun scanner="nmap"
         args="nmap -sV -sC -O -oX - -p 22,80,443,8080 192.168.1.100"
